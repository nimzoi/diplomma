# Environment variables template (copy to .env, fill values, NIE commit)
# .env is gitignored (per .gitignore)

# HuggingFace — dla model downloads + private models access
# Get token: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_xxx

# OpenRouter API — dla cross-model comparison (Qwen 3.5, Gemma 4, Claude, GPT)
# Get key: https://openrouter.ai/keys
# Used w: ablations w R7, judge model comparisons (Bielik vs OpenRouter Gemma 3 27B itd.)
OPENROUTER_API_KEY=sk-or-xxx

# Anthropic API — opcjonalne, dla Claude Haiku jako external comparison
# ANTHROPIC_API_KEY=sk-ant-xxx

# Weights & Biases — opcjonalne, alternatywa MLflow tracking
# WANDB_API_KEY=xxx
# WANDB_PROJECT=polish-citationbench

# MLflow tracking server (jeśli remote, default lokalny)
# MLFLOW_TRACKING_URI=http://localhost:5000

# Qdrant connection (default local Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=xxx       # tylko jeśli Qdrant Cloud

# Langfuse observability — Iter. 3+
# LANGFUSE_PUBLIC_KEY=pk-lf-xxx
# LANGFUSE_SECRET_KEY=sk-lf-xxx
# LANGFUSE_HOST=https://cloud.langfuse.com  # lub self-hosted

# DVC remote storage (MinIO lub S3-compat) — opcjonalne dla bigger datasets w Iter. 1+
# DVC_REMOTE_URL=s3://bucket/path
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx
